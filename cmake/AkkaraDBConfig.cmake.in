# AkkaraDBConfig.cmake.in
# CMake package configuration file for AkkaraDB.
#
# Generated by CMake during the build; consumers use it via:
#
#   find_package(AkkaraDB REQUIRED)
#   target_link_libraries(myapp PRIVATE AkkaraDB::akkaradb)
#
# After find_package() succeeds the following are available:
#   AkkaraDB::akkaradb   — the imported library target
#   AKKARADB_VERSION     — e.g. "0.1.0"
#   AKKARADB_FOUND       — TRUE

@PACKAGE_INIT@

# Pull in the exported target definitions (akkaradb shared/static library).
include("${CMAKE_CURRENT_LIST_DIR}/AkkaraDBTargets.cmake")

# Propagate version info as conventional variables.
set(AKKARADB_VERSION "@PROJECT_VERSION@")
set(AKKARADB_VERSION_MAJOR "@PROJECT_VERSION_MAJOR@")
set(AKKARADB_VERSION_MINOR "@PROJECT_VERSION_MINOR@")
set(AKKARADB_VERSION_PATCH "@PROJECT_VERSION_PATCH@")

# check_required_components validates that every requested COMPONENT is known.
# (AkkaraDB currently exports a single component; extend here if sub-packages
#  such as AkkaraDB::jni or AkkaraDB::binpack are added later.)
check_required_components(AkkaraDB)
